{
  "title": "Credit Risk Scoring API",
  "uid": "credit-risk-api",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/min)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(prediction_requests_total[1m]) * 60",
          "legendFormat": "req/min"
        }
      ]
    },
    {
      "id": 2,
      "title": "P95 Latency (ms)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(prediction_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95 ms"
        }
      ]
    },
    {
      "id": 3,
      "title": "High Risk Rate (% Decline-grade)",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "thresholds": { "steps": [
        { "color": "green", "value": 0 },
        { "color": "yellow", "value": 0.15 },
        { "color": "red", "value": 0.30 }
      ]} },
      "targets": [
        { "expr": "high_risk_rate_ratio", "legendFormat": "E-grade rate" }
      ]
    },
    {
      "id": 4,
      "title": "Score Distribution",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "rate(prediction_score_bucket[5m])",
          "legendFormat": "le={{le}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Predictions by Risk Grade",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (risk_grade) (prediction_requests_total)",
          "legendFormat": "{{risk_grade}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Latency Heatmap",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    }
  ]
}
